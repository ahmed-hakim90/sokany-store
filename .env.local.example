# Toggle mock vs real API — the ONLY thing you change when going live
NEXT_PUBLIC_USE_MOCK=true
# Your Next.js server URL
NEXT_PUBLIC_API_URL=http://localhost:3000
# Site info
NEXT_PUBLIC_SITE_NAME=My WooCommerce Store
# Compact mobile header wordmark (Latin), e.g. SOKANYEgypt
NEXT_PUBLIC_SITE_WORDMARK=SOKANYEgypt
NEXT_PUBLIC_DEFAULT_CURRENCY=EGP
NEXT_PUBLIC_CURRENCY_LOCALE=ar-EG
# WooCommerce — SERVER SIDE ONLY, never use NEXT_PUBLIC_ prefix here
WC_BASE_URL=https://your-store.com
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Mobile header hotline: used when WordPress REST hotline is missing or invalid
STORE_CUSTOMER_HOTLINE=17355
# Optional override for public WP route (default: /wp-json/sokany/v1/hotline)
# WP_HOTLINE_REST_PATH=/wp-json/sokany/v1/hotline
# Auth
JWT_SECRET=your-jwt-secret-here

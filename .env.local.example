# ‎`false`‎ = live Woo only (no snapshot / broken local ‎`/images/sokany-eg/...`‎). ‎`true`‎ = offline / Playwright; uses built-in mock + snapshot when present.
NEXT_PUBLIC_USE_MOCK=false
# Your Next.js server URL
NEXT_PUBLIC_API_URL=http://localhost:3000
# Site info
NEXT_PUBLIC_SITE_NAME=My WooCommerce Store
# Arabic title suffix for SEO (product/category templates). Override e.g. سوكانى مصر
# NEXT_PUBLIC_SITE_BRAND_TITLE_AR=سوكانى المغربى
# Canonical URL in production — required for sitemap, OG, JSON-LD, webhook delivery URLs
# (optional: override with `publicStorefrontBaseUrl` in /control → تكاملات for webhook URLs)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# Google Search Console HTML tag verification (optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Compact mobile header wordmark (Latin), e.g. SOKANYEgypt
NEXT_PUBLIC_SITE_WORDMARK=SOKANYEgypt
# Public logo URL path (file under `public/`). Default: /images/logo.png
# NEXT_PUBLIC_SITE_LOGO_PATH=/brand/logo.webp
NEXT_PUBLIC_DEFAULT_CURRENCY=EGP
NEXT_PUBLIC_CURRENCY_LOCALE=ar-EG
# كارت المنتج: سطر «بيع × مرة» (من ‎Woo total_sales). ‎`false`‎ = إخفاء السطر بالكامل. يُخفى تلقائياً عند ‎< ٥٠‎ مبيعة.
# NEXT_PUBLIC_PRODUCT_CARD_SHOW_SALES_COUNT=true
# مصدر REST لصفحات الشروط/السياسات (افتراضي: sokany-eg.com). غيّره فقط إذا غيّر النطاق الرسمي.
# NEXT_PUBLIC_OFFICIAL_SOKANY_WP_ORIGIN=https://sokany-eg.com
# WooCommerce — SERVER SIDE ONLY, never use NEXT_PUBLIC_ prefix here
# Optional: set `wooBaseUrl` in /control (عام → تكاملات) in Firestore instead; keys always stay here.
WC_BASE_URL=https://sokany-eg.com
WC_CONSUMER_KEY=ck_fc3c14745b2b25b583fef489d6aaaa2fbf2414cb
WC_CONSUMER_SECRET=cs_eded3526cafad3f68bbea682690608a4d63bbb0
# إذا ظهرت من وو ‎`401` / «Consumer Secret غير صالح»‎: أنشئ مفاتيح ‎REST API جديدة من ‎Woo وحدّث ‎`WC_CONSUMER_KEY` + `WC_CONSUMER_SECRET` (المفتاح + السر يجبان أن يتطابقان مع مزوّد الملف في لوحة ووردبريس).
# عند ‎`502`‎ من ‎`/api/products`‎/‎`categories`‎: راقب طرفية ‎`next dev`‎ (يسجل ‎`[woo-bff]‎` بدون كشف مفاتيح) وافتح نفس الـ ‎`GET`‎ لرؤية ‎`dev`‎.
# Optional: `GET /api/dev/woo-status` on non-dev deploys (Authorization: Bearer …). Keep secret; never commit a real value.
# DEV_WOO_DIAG_TOKEN=
# Optional: server-only secret if your custom API (publicReadBaseUrl in CMS) requires a header — never NEXT_PUBLIC_*
# INTEGRATION_SERVER_SECRET=
# Secret — same value in Woo → Settings → Advanced → Webhooks (signing key). Delivery URL: `https://<your-domain>/api/webhooks/woocommerce` (see /control/woo-api). Topics: product.*, product_cat.* recommended.
WC_WEBHOOK_SECRET=your-webhook-secret-from-wp-admin
# ويب هووك من API/سيرفر خارجي — HMAC-SHA256(body) → Base64 في الهيدر (منفصل عن Woo). رابط الاستقبال: `https://<your-domain>/api/webhooks/external-data` — انظر /control/woo-api
# EXTERNAL_DATA_WEBHOOK_SECRET=shared-secret-with-external-server
# Optional header name (default: X-External-Webhook-Signature)
# EXTERNAL_DATA_WEBHOOK_HEADER=
# Mobile header hotline: used when WordPress REST hotline is missing or invalid
STORE_CUSTOMER_HOTLINE=17355
# Optional override for public WP route (default: /wp-json/sokany/v1/hotline)
# WP_HOTLINE_REST_PATH=/wp-json/sokany/v1/hotline
# Auth — مطلوب لجلسة WooCommerce وللوحة /control (توقيع كوكي المشرف)
JWT_SECRET=TUILXORP84Jt2+FlU6CAewfgtarYer+2DsUbh4uf9GE=
# بديل اختياري إن أردت سراً منفصلاً للوحة التحكم فقط:
# CONTROL_SESSION_JWT_SECRET=
# Microsoft Clarity — session replay / heatmaps. Omit for default project; set empty to disable.
# NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Google Analytics 4 — omit for default measurement ID; set empty to disable.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
#
# Firebase (client) — Phone Auth + Firestore `storefront_customers/{uid}`
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
#
# Firebase Admin (server only) — verify ID tokens + read Firestore in `/api/auth/firebase`
# Paste the full service account JSON as a single line (Project settings → Service accounts → Generate new private key).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# لوحة التحكم (/control) — UIDs مسموحة من Firebase Auth (مفصولة بفواصل)
# CONTROL_PANEL_ALLOWED_UIDS=uid1,uid2
# UIDs يرون تبويب الوسائط فقط (تخزين: cms/site-media/...) — لا يلغي الصلاحية الكاملة إن كان نفس الـUID في السطر أعلاه
# CONTROL_PANEL_MEDIA_ONLY_UIDS=uid3,uid4
# UIDs يرون تبويب «الصلاحيات» و API إدارة ‎`controlPanelAccess`‎ (أو أضف الـUID هنا → إعادة دخول)
# CONTROL_PANEL_SUPER_ADMIN_UIDS=uid1
# صلاحيات دقيقة: وثيقة ‎`controlPanelAccess/{uid}‎` في Firestore (mode, tabIds, mediaSubfolders) — أولوية على قوائم UIDs أعلاه
#
# Web Push (اختياري) — إشعارات FCM للويب
# 1) نفس مشروع Firebase المستخدم في NEXT_PUBLIC_FIREBASE_PROJECT_ID أعلاه.
# 2) Firebase Console → Project settings (⚙) → Cloud Messaging → Web Push certificates.
# 3) Generate key pair إن لم يوجد، ثم انسخ المفتاح العام (Public key) — وليس Legacy server key.
# 4) سطر واحد بدون علامات اقتباس أو أسطر إضافية. أعد تشغيل `next dev` بعد التغيير.
# إن ظهر خطأ VAPID راجع docs/firebase-web-push-vapid.md
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=
